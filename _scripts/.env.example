# ============================================
# .env.example — Variables de entorno para Docker
# ============================================
# Copia este archivo como .env en la raíz o en _scripts/:
#   cp _scripts/.env.example _scripts/.env
#
# ⚠️  NUNCA subas .env al repositorio.
#     El .gitignore ya lo excluye automáticamente.
# ============================================

# Credenciales de MongoDB (solo para entorno local de aprendizaje)
MONGO_USERNAME=bootcamp
MONGO_PASSWORD=bootcamp123
MONGO_DATABASE=bootcamp_db

# Puerto expuesto en el host (cambiar si el 27017 está ocupado)
MONGO_PORT=27017
